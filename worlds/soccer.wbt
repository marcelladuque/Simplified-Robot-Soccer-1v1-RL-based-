DEF LINE_LEFT Solid {
  translation -1.5 0.001 0
  name "line_left"
  children [
    Shape {
      appearance USE LINE_APP
      geometry Box { size 0.022 0.002 2.044 }
    }
  ]
  locked TRUE
}

# Right end-line  x = +1.5
DEF LINE_RIGHT Solid {
  translation 1.5 0.001 0
  name "line_right"
  children [
    Shape {
      appearance USE LINE_APP
      geometry Box { size 0.022 0.002 2.044 }
    }
  ]
  locked TRUE
}

# Centre line  x = 0
DEF LINE_CTR Solid {
  translation 0 0.001 0
  name "line_ctr"
  children [
    Shape {
      appearance USE LINE_APP
      geometry Box { size 0.022 0.002 2.0 }
    }
  ]
  locked TRUE
}

# Centre circle – flat ring drawn as an IndexedFaceSet (32 quad faces).
# Inner radius 0.339 m, outer radius 0.361 m → 22 mm line width matching all
# other field lines.  Points lie in the local XZ plane (Y=0); the Solid's
# translation lifts the ring 2 mm above the floor to prevent z-fighting.
DEF CENTRE_CIRCLE Solid {
  translation 0 0.002 0
  name "centre_circle"
  children [
    Shape {
      appearance USE LINE_APP
      geometry IndexedFaceSet {
        coord Coordinate {
          point [
            # Inner ring  r = 0.339 m  (indices 0 – 31)
             0.3390 0  0.0000   0.3325 0  0.0661   0.3132 0  0.1297   0.2819 0  0.1883
             0.2397 0  0.2397   0.1883 0  0.2819   0.1297 0  0.3132   0.0661 0  0.3325
             0.0000 0  0.3390  -0.0661 0  0.3325  -0.1297 0  0.3132  -0.1883 0  0.2819
            -0.2397 0  0.2397  -0.2819 0  0.1883  -0.3132 0  0.1297  -0.3325 0  0.0661
            -0.3390 0  0.0000  -0.3325 0 -0.0661  -0.3132 0 -0.1297  -0.2819 0 -0.1883
            -0.2397 0 -0.2397  -0.1883 0 -0.2819  -0.1297 0 -0.3132  -0.0661 0 -0.3325
             0.0000 0 -0.3390   0.0661 0 -0.3325   0.1297 0 -0.3132   0.1883 0 -0.2819
             0.2397 0 -0.2397   0.2819 0 -0.1883   0.3132 0 -0.1297   0.3325 0 -0.0661
            # Outer ring  r = 0.361 m  (indices 32 – 63)
             0.3610 0  0.0000   0.3541 0  0.0704   0.3335 0  0.1382   0.3002 0  0.2006
             0.2553 0  0.2553   0.2006 0  0.3002   0.1382 0  0.3335   0.0704 0  0.3541
             0.0000 0  0.3610  -0.0704 0  0.3541  -0.1382 0  0.3335  -0.2006 0  0.3002
            -0.2553 0  0.2553  -0.3002 0  0.2006  -0.3335 0  0.1382  -0.3541 0  0.0704
            -0.3610 0  0.0000  -0.3541 0 -0.0704  -0.3335 0 -0.1382  -0.3002 0 -0.2006
            -0.2553 0 -0.2553  -0.2006 0 -0.3002  -0.1382 0 -0.3335  -0.0704 0 -0.3541
             0.0000 0 -0.3610   0.0704 0 -0.3541   0.1382 0 -0.3335   0.2006 0 -0.3002
             0.2553 0 -0.2553   0.3002 0 -0.2006   0.3335 0 -0.1382   0.3541 0 -0.0704
          ]
        }
        coordIndex [
           0  1 33 32 -1   1  2 34 33 -1   2  3 35 34 -1   3  4 36 35 -1
           4  5 37 36 -1   5  6 38 37 -1   6  7 39 38 -1   7  8 40 39 -1
           8  9 41 40 -1   9 10 42 41 -1  10 11 43 42 -1  11 12 44 43 -1
          12 13 45 44 -1  13 14 46 45 -1  14 15 47 46 -1  15 16 48 47 -1
          16 17 49 48 -1  17 18 50 49 -1  18 19 51 50 -1  19 20 52 51 -1
          20 21 53 52 -1  21 22 54 53 -1  22 23 55 54 -1  23 24 56 55 -1
          24 25 57 56 -1  25 26 58 57 -1  26 27 59 58 -1  27 28 60 59 -1
          28 29 61 60 -1  29 30 62 61 -1  30 31 63 62 -1  31  0 32 63 -1
        ]
        solid FALSE
        creaseAngle 0
      }
    }
  ]
  locked TRUE
}

# Centre spot
DEF CTR_SPOT Solid {
  translation 0 0.002 0
  name "ctr_spot"
  children [
    Shape {
      appearance USE LINE_APP
      geometry Cylinder {
        height 0.003
        radius 0.035
      }
    }
  ]
  locked TRUE
}

# ── Penalty boxes ────────────────────────────────────────────────────────────
# Left penalty area: x ∈ [-1.5, -1.1],  z ∈ [-0.5, +0.5]
DEF GA_L_TOP  Solid { translation -1.30 0.001  0.50 name "ga_l_top"  children [ Shape { appearance USE LINE_APP geometry Box { size 0.40 0.002 0.022 } } ] locked TRUE }
DEF GA_L_BOT  Solid { translation -1.30 0.001 -0.50 name "ga_l_bot"  children [ Shape { appearance USE LINE_APP geometry Box { size 0.40 0.002 0.022 } } ] locked TRUE }
DEF GA_L_SIDE Solid { translation -1.10 0.001  0.00 name "ga_l_side" children [ Shape { appearance USE LINE_APP geometry Box { size 0.022 0.002 1.00  } } ] locked TRUE }
# Right penalty area: x ∈ [+1.1, +1.5],  z ∈ [-0.5, +0.5]
DEF GA_R_TOP  Solid { translation  1.30 0.001  0.50 name "ga_r_top"  children [ Shape { appearance USE LINE_APP geometry Box { size 0.40 0.002 0.022 } } ] locked TRUE }
DEF GA_R_BOT  Solid { translation  1.30 0.001 -0.50 name "ga_r_bot"  children [ Shape { appearance USE LINE_APP geometry Box { size 0.40 0.002 0.022 } } ] locked TRUE }
DEF GA_R_SIDE Solid { translation  1.10 0.001  0.00 name "ga_r_side" children [ Shape { appearance USE LINE_APP geometry Box { size 0.022 0.002 1.00  } } ] locked TRUE }

