# Solid dark-gray arena boards - 0.10m thick sidelines, 0.08m thick end sections
DEF WALL_NEAR Solid {
  translation 0 0.175 1.05
  name "wall_near"
  children [
    Shape {
      appearance DEF WALL_APP PBRAppearance {
        baseColor 0.28 0.28 0.28
        roughness 0.85
        metalness 0.05
      }
      geometry Box {
        size 3.28 0.35 0.1
      }
    }
  ]
  boundingObject Box {
    size 3.28 0.35 0.1
  }
  locked TRUE
}
DEF WALL_FAR Solid {
  translation 0 0.175 -1.05
  name "wall_far"
  children [
    Shape {
      appearance USE WALL_APP
      geometry Box {
        size 3.28 0.35 0.1
      }
    }
  ]
  boundingObject Box {
    size 3.28 0.35 0.1
  }
  locked TRUE
}
# End-wall corner sections start at z=+/-0.39 (just outside goal-post outer
# edge at z=+/-0.375) so their bounding objects never overlap the goal posts.
# Gap = 0.015 m < ball radius (0.043 m), so the ball cannot escape.
DEF ENDW_L_TOP Solid {
  translation -1.54 0.175 0.695
  name "endw_l_top"
  children [
    Shape {
      appearance USE WALL_APP
      geometry Box {
        size 0.08 0.35 0.61
      }
    }
  ]
  boundingObject Box {
    size 0.08 0.35 0.61
  }
  locked TRUE
}
DEF ENDW_L_BOT Solid {
  translation -1.54 0.175 -0.695
  name "endw_l_bot"
  children [
    Shape {
      appearance USE WALL_APP
      geometry Box {
        size 0.08 0.35 0.61
      }
    }
  ]
  boundingObject Box {
    size 0.08 0.35 0.61
  }
  locked TRUE
}
DEF ENDW_R_TOP Solid {
  translation 1.54 0.175 0.695
  name "endw_r_top"
  children [
    Shape {
      appearance USE WALL_APP
      geometry Box {
        size 0.08 0.35 0.61
      }
    }
  ]
  boundingObject Box {
    size 0.08 0.35 0.61
  }
  locked TRUE
}
DEF ENDW_R_BOT Solid {
  translation 1.54 0.175 -0.695
  name "endw_r_bot"
  children [
    Shape {
      appearance USE WALL_APP
      geometry Box {
        size 0.08 0.35 0.61
      }
    }
  ]
  boundingObject Box {
    size 0.08 0.35 0.61
  }
  locked TRUE
}

# ─────────────────────────────────────────────────────────────────────────────
#  SOCCER BALL
#  radius = 0.043 m (≈ size-1 ball scaled for E-puck arena)
#  mass   = 40 g
# ─────────────────────────────────────────────────────────────────────────────
DEF BALL Solid {
  translation 0 0.043 0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 1 1
        roughness 0.5
        metalness 0
      }
      geometry Sphere {
        radius 0.043
        subdivision 2
      }
    }
  ]
  name "ball"
  contactMaterial "ball"
  boundingObject Sphere { radius 0.043 }
  physics Physics {
    density -1
    mass 0.04
  }
}

# ─────────────────────────────────────────────────────────────────────────────
#  ROBOTS
#  Blue  starts in left half facing right  (+X)
#  Red   starts in right half facing left  (-X)
# ─────────────────────────────────────────────────────────────────────────────
DEF ROBOT_BLUE E-puck {
  translation -0.75 0 0
  rotation 0 1 0 0
  name "robot_blue"
  controller "robot_controller"
}

DEF ROBOT_RED E-puck {
  translation 0.75 0 0
  rotation 0 1 0 3.14159265
  name "robot_red"
  controller "robot_controller"
}

# ─────────────────────────────────────────────────────────────────────────────
#  SUPERVISOR  (invisible Robot used by the RL training loop)
# ─────────────────────────────────────────────────────────────────────────────
DEF SUPERVISOR Robot {
  translation 0 0.5 0
  name "supervisor"
  controller "supervisor_controller"
  supervisor TRUE
  children [
    Emitter {
      name "emitter_blue"
      channel -1
    }
    Emitter {
      name "emitter_red"
      channel -1
    }
  ]
}
