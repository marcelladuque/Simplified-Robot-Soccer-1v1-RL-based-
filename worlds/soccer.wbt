#VRML_SIM R2025a utf8

# ─────────────────────────────────────────────────────────────────────────────
#  WORLD INFO
#  Field:  3.0 m (X, long)  ×  2.0 m (Z, short)   Y = up
#  Left goal mouth at x = -1.5 m   |   Right goal mouth at x = +1.5 m
#  Goal: 0.70 m wide (Z) × 0.40 m tall (Y) × 0.25 m deep (X)
#
#  Robots: Competition RoboCup F180 / SSL style
#    TITAN  (ROBOT_BLUE) – ø180 mm × 64 mm, wheel r=32 mm,  5 rad/s, 1.50 kg – defensive
#    VIPER  (ROBOT_RED)  – ø140 mm × 52 mm, wheel r=26 mm, 14 rad/s, 0.70 kg – offensive
#  Ball: futsal-style orange sphere (ø86 mm, 40 g)
# ─────────────────────────────────────────────────────────────────────────────
WorldInfo {
  title "Simplified Robot Soccer - 1v1"
  basicTimeStep 64
  contactProperties [
    # Ball vs floor: no bounce, moderate friction so ball rolls freely
    ContactProperties {
      material1 "ball"
      coulombFriction [ 0.5 ]
      bounce 0.0
      bounceVelocity 0.001
      softCFM 0.0001
    }
    # Ball vs robot body: no bounce, low friction for smooth deflection
    ContactProperties {
      material1 "ball"
      material2 "robot"
      coulombFriction [ 0.2 ]
      bounce 0.0
      bounceVelocity 0.001
    }
  ]
}

Viewpoint {
  fieldOfView 1.0
  orientation -1 0 0 1.5707963
  position 0 4.5 0
}

Background {
  skyColor [
    0.15 0.15 0.18
  ]
}
# Overhead key light
DirectionalLight {
  direction 0 -1 0
  intensity 0.8
}
# Front-left fill
DirectionalLight {
  direction -0.4 -0.7 -0.6
  intensity 0.5
}
# Back-right fill (removes dark patches on far side of field)
DirectionalLight {
  direction 0.4 -0.7 0.6
  intensity 0.4
}
# Camera-direction fill (ensures near sideline is always lit)
DirectionalLight {
  direction 0 -0.5 -1
  intensity 0.3
}

# ── FIELD FLOOR  (top surface at y = 0) ─────────────────────────────────────
DEF FIELD_FLOOR Solid {
  translation 0 -0.02 0
  name "field_floor"
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.13 0.55 0.13
        roughness 0.95
        metalness 0
      }
      geometry Box {
        size 4.2 0.04 3.2
      }
    }
  ]
  contactMaterial "floor"
  boundingObject Box {
    size 4.2 0.04 3.2
  }
  locked TRUE
}

# ─────────────────────────────────────────────────────────────────────────────
#  FIELD LINES  (purely visual – no boundingObject)
# ─────────────────────────────────────────────────────────────────────────────

# Top sideline  z = +1.0
DEF LINE_TOP Solid {
  translation 0 0.001 1.0
  name "line_top"
  children [
    Shape {
      appearance DEF LINE_APP PBRAppearance {
        baseColor 1 1 1
        roughness 0.5
        metalness 0
      }
      geometry Box { size 3.04 0.002 0.022 }
    }
  ]
  locked TRUE
}

