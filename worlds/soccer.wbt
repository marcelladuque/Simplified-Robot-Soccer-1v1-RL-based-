DEF LINE_BOT Solid {
  translation 0 0.001 -1.0
  name "line_bot"
  children [
    Shape {
      appearance USE LINE_APP
      geometry Box { size 3.04 0.002 0.022 }
    }
  ]
  locked TRUE
}

